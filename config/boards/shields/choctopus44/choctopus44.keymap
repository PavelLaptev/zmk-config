/*
 * DIAGNOSTIC KEYMAP — one unique character per raw matrix position.
 * Decoder (char -> row,col):
 *   row0: 1 2 3 4 5 6      row1: 7 8 9 0 - =
 *   row2: q w e r t y      row3: u i o p [ ]
 *   row4: a s d f g h      row5: j k l ; ' \
 *   row6: z x c v b n      row7: m , . / ` !
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
  keymap {
    compatible = "zmk,keymap";

    default_layer {
      bindings = <
        &kp N1   &kp N2     &kp N3   &kp N4    &kp N5     &kp N6
        &kp N7   &kp N8     &kp N9   &kp N0    &kp MINUS  &kp EQUAL
        &kp Q    &kp W      &kp E    &kp R     &kp T      &kp Y
        &kp U    &kp I      &kp O    &kp P     &kp LBKT   &kp RBKT
        &kp A    &kp S      &kp D    &kp F     &kp G      &kp H
        &kp J    &kp K      &kp L    &kp SEMI  &kp SQT    &kp BSLH
        &kp Z    &kp X      &kp C    &kp V     &kp B      &kp N
        &kp M    &kp COMMA  &kp DOT  &kp FSLH  &kp GRAVE  &kp LS(N1)
      >;
    };
  };
};
