#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        // No zmk,matrix_transform here: the transform is referenced by the
        // physical layout below, which is required for ZMK Studio support.
        zmk,physical-layout = &choctopus44_layout;
        zmk,battery = &vbatt;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <6>;
        rows = <8>;

        // Corrected for the beekeeb ChocoTako44 wiring, mapped empirically
        // via a diagnostic identity-matrix build:
        //   scan row 0=top-left  1=mid-left  2=bot-left  3=top-right
        //   5=center+left-thumbs 6=bot-right 7=mid-right
        //   4 (pin D10/"B6") = right thumbs, cols 0-3 (B6 row trace was
        //       broken from the factory; repaired with a bodge wire)
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)         RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)         RC(7,0) RC(7,1) RC(7,2) RC(7,3) RC(7,4) RC(7,5)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(5,0) RC(6,0) RC(6,1) RC(6,2) RC(6,3) RC(6,4) RC(6,5)
                RC(5,2) RC(5,3) RC(5,4) RC(5,5)         RC(4,0) RC(4,1) RC(4,2) RC(4,3)
        >;
    };

    choctopus44_layout: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Choctopus44";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        keys  //                     w   h    x    y   rot   rx   ry
            // Row 0 (top) - left
            = <&key_physical_attrs 100 100    0   37     0    0    0>
            , <&key_physical_attrs 100 100  100   37     0    0    0>
            , <&key_physical_attrs 100 100  200   12     0    0    0>
            , <&key_physical_attrs 100 100  300    0     0    0    0>
            , <&key_physical_attrs 100 100  400   12     0    0    0>
            , <&key_physical_attrs 100 100  500   24     0    0    0>
            // Row 0 (top) - right
            , <&key_physical_attrs 100 100  800   24     0    0    0>
            , <&key_physical_attrs 100 100  900   12     0    0    0>
            , <&key_physical_attrs 100 100 1000    0     0    0    0>
            , <&key_physical_attrs 100 100 1100   12     0    0    0>
            , <&key_physical_attrs 100 100 1200   37     0    0    0>
            , <&key_physical_attrs 100 100 1300   37     0    0    0>
            // Row 1 (home) - left
            , <&key_physical_attrs 100 100    0  137     0    0    0>
            , <&key_physical_attrs 100 100  100  137     0    0    0>
            , <&key_physical_attrs 100 100  200  112     0    0    0>
            , <&key_physical_attrs 100 100  300  100     0    0    0>
            , <&key_physical_attrs 100 100  400  112     0    0    0>
            , <&key_physical_attrs 100 100  500  124     0    0    0>
            // Row 1 (home) - right
            , <&key_physical_attrs 100 100  800  124     0    0    0>
            , <&key_physical_attrs 100 100  900  112     0    0    0>
            , <&key_physical_attrs 100 100 1000  100     0    0    0>
            , <&key_physical_attrs 100 100 1100  112     0    0    0>
            , <&key_physical_attrs 100 100 1200  137     0    0    0>
            , <&key_physical_attrs 100 100 1300  137     0    0    0>
            // Row 2 (bottom) - left
            , <&key_physical_attrs 100 100    0  237     0    0    0>
            , <&key_physical_attrs 100 100  100  237     0    0    0>
            , <&key_physical_attrs 100 100  200  212     0    0    0>
            , <&key_physical_attrs 100 100  300  200     0    0    0>
            , <&key_physical_attrs 100 100  400  212     0    0    0>
            , <&key_physical_attrs 100 100  500  224     0    0    0>
            // Center key (encoder push / RC(3,0))
            , <&key_physical_attrs 100 100  650  237     0    0    0>
            // Row 2 (bottom) - right
            , <&key_physical_attrs 100 100  800  224     0    0    0>
            , <&key_physical_attrs 100 100  900  212     0    0    0>
            , <&key_physical_attrs 100 100 1000  200     0    0    0>
            , <&key_physical_attrs 100 100 1100  212     0    0    0>
            , <&key_physical_attrs 100 100 1200  237     0    0    0>
            , <&key_physical_attrs 100 100 1300  237     0    0    0>
            // Thumb row - left
            , <&key_physical_attrs 100 100  200  325     0    0    0>
            , <&key_physical_attrs 100 100  300  325     0    0    0>
            , <&key_physical_attrs 100 100  400  325     0    0    0>
            , <&key_physical_attrs 100 100  500  325     0    0    0>
            // Thumb row - right
            , <&key_physical_attrs 100 100  800  325     0    0    0>
            , <&key_physical_attrs 100 100  900  325     0    0    0>
            , <&key_physical_attrs 100 100 1000  325     0    0    0>
            , <&key_physical_attrs 100 100 1100  325     0    0    0>
        ;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";
        diode-direction = "col2row";

        row-gpios
            = <&pro_micro 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 19 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 18 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 16 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 14 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };

    middle_encoder: encoder_middle {
        compatible = "alps,ec11";
        label = "MIDDLE_ENCODER";
        a-gpios = <&pro_micro 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&pro_micro 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <15>;
        status = "enabled";
    };

    sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&middle_encoder>;
        triggers-per-rotation = <15>;
    };

    vbatt: vbatt {
        compatible = "zmk,battery-nrf-vddh";
        label = "VBATT";
    };
};
